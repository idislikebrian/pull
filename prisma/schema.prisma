generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CampaignStatus {
  DRAFT
  LIVE
  FUNDED
  GREENLIT
  EXPIRED
  CANCELLED
}

enum PledgeType {
  SOFT
  HARD
}

enum PaymentStatus {
  NOT_REQUIRED
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
  CANCELLED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum OnboardingStatus {
  HANDLE_ASSIGNED
  COMPLETE
}

enum IdentityProvider {
  PRIVY_PHONE
  PRIVY_EMAIL
  PRIVY_WALLET
  PRIVY_PASSKEY
  PRIVY_SOCIAL
}

model User {
  id                  String             @id @default(cuid())
  privyUserId         String?            @unique
  handle              String             @unique
  email               String?            @unique
  avatarUrl           String?
  onboardingStatus    OnboardingStatus   @default(HANDLE_ASSIGNED)
  status              UserStatus         @default(ACTIVE)
  isLegacyPlaceholder Boolean            @default(false)
  handleCustomizedAt  DateTime?
  lastLoginAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  identityAccounts    IdentityAccount[]
  campaigns           Campaign[]
  pledges             Pledge[]
}

model IdentityAccount {
  id                String           @id @default(cuid())
  userId            String
  provider          IdentityProvider
  providerAccountId String
  normalizedValue   String?
  displayValue      String?
  verifiedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Campaign {
  id               String         @id @default(cuid())
  slug             String         @unique
  title            String
  artistName       String
  venueName        String
  googlePlaceId    String?
  formattedAddress String?
  latitude         Float?
  longitude        Float?
  city             String
  neighborhood     String?
  countryCode      String?
  dateWindow       String
  description      String
  fundingGoal      Int
  deadline         DateTime
  status           CampaignStatus @default(DRAFT)
  imageUrl         String?
  creatorId        String
  creator          User           @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  pledges          Pledge[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([status, deadline])
  @@index([city])
  @@index([googlePlaceId])
  @@index([latitude, longitude])
  @@index([countryCode, city])
}

model Pledge {
  id              String        @id @default(cuid())
  userId          String
  campaignId      String
  amount          Int
  type            PledgeType
  paymentStatus   PaymentStatus @default(NOT_REQUIRED)
  stripeIntentId  String?
  createdAt       DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign        Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
  @@index([campaignId, type])
  @@index([userId])
}
